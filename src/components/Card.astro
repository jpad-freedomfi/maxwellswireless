---
interface Props {
  href?: string;
  class?: string;
}

const { href, class: className } = Astro.props;
const Tag = href ? 'a' : 'div';
---

<Tag
  href={href}
  class:list={[
    'block rounded-xl border border-primary/20 bg-white p-6 shadow-sm transition-all',
    href && 'hover:shadow-md hover:border-accent/30 hover:-translate-y-0.5',
    className,
  ]}
>
  <slot />
</Tag>
