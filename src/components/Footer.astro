---
const currentYear = new Date().getFullYear();
---

<footer class="border-t border-primary/20 bg-secondary/5">
  <div class="max-w-content mx-auto px-6 py-12">
    <div class="flex flex-col md:flex-row justify-between items-start md:items-center gap-8">
      <div>
        <a href="/" class="flex items-center gap-3">
          <img src="/images/logo-vertical.png" alt="Maxwell's Wireless" class="h-8 w-auto" />
          <span class="font-bold text-secondary">Maxwell's Wireless</span>
        </a>
        <p class="mt-2 text-sm text-foreground/60 max-w-sm">
          Engineer. Founder. Architect of what's next in wireless.
        </p>
      </div>
      <div class="flex flex-col sm:flex-row gap-8 text-sm">
        <div>
          <h4 class="font-semibold text-secondary mb-2">Navigate</h4>
          <ul class="space-y-1 text-foreground/60">
            <li><a href="/about" class="hover:text-accent transition-colors">About</a></li>
            <li><a href="/experience" class="hover:text-accent transition-colors">Experience</a></li>
            <li><a href="/projects" class="hover:text-accent transition-colors">Projects</a></li>
            <li><a href="/patents" class="hover:text-accent transition-colors">Patents</a></li>
          </ul>
        </div>
        <div>
          <h4 class="font-semibold text-secondary mb-2">Connect</h4>
          <ul class="space-y-1 text-foreground/60">
            <li><a href="/insights" class="hover:text-accent transition-colors">Insights</a></li>
            <li><a href="/contact" class="hover:text-accent transition-colors">Contact</a></li>
            <li><a href="https://www.linkedin.com/in/joey-padden-22a69a3/" target="_blank" rel="noopener" class="hover:text-accent transition-colors">LinkedIn</a></li>
          </ul>
        </div>
      </div>
    </div>
    <div class="mt-8 pt-8 border-t border-primary/10 text-center text-xs text-foreground/40">
      &copy; {currentYear} Maxwell's Wireless. All rights reserved.
    </div>
  </div>
</footer>
