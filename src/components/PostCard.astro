---
interface Props {
  title: string;
  description: string;
  date: string;
  slug: string;
  tags?: string[];
}

const { title, description, date, slug, tags } = Astro.props;
const formattedDate = new Date(date).toLocaleDateString('en-US', {
  year: 'numeric',
  month: 'short',
  day: 'numeric',
});
---

<a href={`/insights/${slug}`} class="block rounded-xl border border-primary/20 bg-white p-6 shadow-sm hover:shadow-md hover:border-accent/30 hover:-translate-y-0.5 transition-all">
  <div class="flex items-center gap-3 mb-3">
    <time datetime={date} class="text-xs text-foreground/50 font-medium">{formattedDate}</time>
    {tags && tags.slice(0, 2).map((tag) => (
      <span class="bg-accent/10 text-accent px-2 py-0.5 rounded text-xs font-medium">{tag}</span>
    ))}
  </div>
  <h3 class="text-lg font-bold text-secondary mb-2 group-hover:text-accent">{title}</h3>
  <p class="text-foreground/60 text-sm leading-relaxed line-clamp-2">{description}</p>
  <span class="inline-block mt-3 text-sm font-medium text-accent">Read more &rarr;</span>
</a>
