---
interface Props {
  title: string;
  description: string;
  tags?: string[];
  href?: string;
  period?: string;
}

const { title, description, tags, href, period } = Astro.props;
---

<div class="rounded-xl border border-primary/20 bg-white p-6 shadow-sm hover:shadow-md hover:border-accent/30 transition-all">
  {period && <div class="text-xs font-medium text-accent mb-2">{period}</div>}
  <h3 class="text-xl font-bold text-secondary mb-2">{title}</h3>
  <p class="text-foreground/70 leading-relaxed mb-4">{description}</p>
  {tags && tags.length > 0 && (
    <div class="flex flex-wrap gap-2">
      {tags.map((tag) => (
        <span class="bg-primary/15 text-secondary px-2.5 py-0.5 rounded-full text-xs font-medium">{tag}</span>
      ))}
    </div>
  )}
  {href && (
    <a href={href} class="inline-block mt-4 text-sm font-medium text-accent hover:underline">
      Learn more &rarr;
    </a>
  )}
</div>
