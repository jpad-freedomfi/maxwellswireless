---
interface Props {
  title: string;
  description: string;
  ogImage?: string;
}

const { title, description, ogImage } = Astro.props;
const canonicalURL = new URL(Astro.url.pathname, Astro.site);
const fullTitle = title.includes('Maxwell') ? title : `${title} | Maxwell's Wireless`;
---

<meta charset="UTF-8" />
<meta name="viewport" content="width=device-width, initial-scale=1.0" />
<meta name="generator" content={Astro.generator} />

<title>{fullTitle}</title>
<meta name="description" content={description} />
<link rel="canonical" href={canonicalURL} />

<!-- Favicon -->
<link rel="icon" type="image/png" href="/images/logo-vertical.png" />

<!-- Open Graph -->
<meta property="og:type" content="website" />
<meta property="og:url" content={canonicalURL} />
<meta property="og:title" content={fullTitle} />
<meta property="og:description" content={description} />
{ogImage && <meta property="og:image" content={ogImage} />}

<!-- Twitter -->
<meta name="twitter:card" content="summary_large_image" />
<meta name="twitter:title" content={fullTitle} />
<meta name="twitter:description" content={description} />

<!-- JSON-LD Person Schema -->
<script type="application/ld+json" set:html={JSON.stringify({
  "@context": "https://schema.org",
  "@type": "Person",
  "name": "Joey Padden",
  "jobTitle": "VP, Network Architecture",
  "worksFor": { "@type": "Organization", "name": "Helium / Nova Labs" },
  "url": "https://maxwellswireless.com",
  "sameAs": ["https://www.linkedin.com/in/joey-padden-22a69a3/"],
  "alumniOf": { "@type": "CollegeOrUniversity", "name": "University of Colorado" },
  "knowsAbout": ["Wireless Engineering", "Telecom Infrastructure", "Patent Development", "CBRS", "5G", "Wi-Fi", "Blockchain Telecom"]
})} />
