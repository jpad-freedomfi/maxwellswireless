---
interface Props {
  skills: string[];
}

const { skills } = Astro.props;
---

<div class="flex flex-wrap gap-2.5">
  {skills.map((skill) => (
    <span class="px-4 py-2 bg-white border border-primary/20 rounded-lg text-sm font-medium text-secondary hover:border-accent/40 hover:bg-accent/5 transition-colors">
      {skill}
    </span>
  ))}
</div>
