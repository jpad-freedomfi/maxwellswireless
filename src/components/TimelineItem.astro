---
interface Props {
  period: string;
  role: string;
  company: string;
  description: string;
  highlights?: string[];
}

const { period, role, company, description, highlights } = Astro.props;
---

<div class="relative pl-8 pb-12 border-l-2 border-primary/30 last:pb-0">
  <div class="absolute -left-[9px] top-1 w-4 h-4 rounded-full bg-accent border-2 border-background" />
  <div class="text-sm font-medium text-accent mb-1">{period}</div>
  <h3 class="text-xl font-bold text-secondary">{role}</h3>
  <div class="text-foreground/60 font-medium mb-2">{company}</div>
  <p class="text-foreground/80 leading-relaxed">{description}</p>
  {highlights && highlights.length > 0 && (
    <ul class="mt-3 space-y-1">
      {highlights.map((h) => (
        <li class="flex items-start gap-2 text-sm text-foreground/70">
          <span class="text-accent mt-1.5 shrink-0">&#9656;</span>
          <span>{h}</span>
        </li>
      ))}
    </ul>
  )}
</div>
