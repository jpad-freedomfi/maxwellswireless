---
import BaseLayout from '../layouts/BaseLayout.astro';
import Button from '../components/Button.astro';
---

<BaseLayout title="Page Not Found" description="The page you're looking for doesn't exist.">
  <section class="max-w-content mx-auto px-6 py-32 text-center">
    <h1 class="text-6xl font-extrabold text-secondary mb-4">404</h1>
    <p class="text-xl text-foreground/60 mb-8">The page you're looking for doesn't exist.</p>
    <Button href="/">Back to Home</Button>
  </section>
</BaseLayout>
